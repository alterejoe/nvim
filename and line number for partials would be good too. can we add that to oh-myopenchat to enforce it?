		local label = (conv.label or ""):gsub("\n", " "):sub(1, 70)
		if label ~= "" then
			entries[#entries + 1] = {
				display = ("── %s ──"):format(label),
				make_display = function()
					return { { "Title", ("── %s ──"):format(label) } }
				end,
				ordinal = label,
				section_header = true,
				user_label = label,
				value = {},
			}
		end
		for _, asst in ipairs(conv.asst_sections) do
			local per_block_ctx = compute_per_block_contexts(asst.text_lines or {}, asst.code_blocks)
			for bi, cb in ipairs(asst.code_blocks) do
				local context = per_block_ctx[bi] or {}
				local step_tag = detect_steps(context)
				local path, candidates = resolve_path(cb.lines, context, project_path)
				local version = detect_version(cb.lines)
				local snippet = code_snippet(cb.lines)
				local lt = cb.lang ~= "" and "(" .. cb.lang .. ")" or "(?)"

				-- Status icon for path resolution
				local path_exists = path ~= ""
					and project_path
					and vim.fn.filereadable(project_path .. "/" .. path) == 1
				local icon = path_exists and "✓" or (path ~= "" and "▸") or (#candidates > 0 and "?") or "○"
				local icon_hl = path_exists and "Identifier"
					or (path ~= "" and "Special")
					or (#candidates > 0 and "WarningMsg")
					or "NonText"

				-- Plain text display (string, for telescope compatibility)
				local display
				if path ~= "" then
					display = icon .. string.format(" %-28s %s", path, snippet)
				else
					display = icon .. string.format(" %-8s %s", lt, snippet)
				end
				if step_tag ~= "" then
					display = step_tag .. ": " .. display
				end
				-- Sorting/filter string
				local ord = (step_tag ~= "" and step_tag .. " " or "") .. (path ~= "" and path or lt) .. " " .. snippet

				entries[#entries + 1] = {
					display = display,
					ordinal = ord,
					make_display = function()
						local parts = {}
						if step_tag ~= "" then
							table.insert(parts, { "Title", step_tag .. ": " })
						end
						table.insert(parts, { icon_hl, icon })
						table.insert(parts, { "Normal", " " })
						if path ~= "" then
							table.insert(parts, { "Directory", string.format("%-28s", path) })
						else
							table.insert(parts, { "Comment", string.format("%-8s", lt) })
						end
						table.insert(parts, { "Normal", " " })
						table.insert(parts, { "String", snippet })
						return parts
					end,
					value = {
						lines = cb.lines,
						context = context,
						lang = cb.lang,
						path = path,
						candidates = candidates,
						path_exists = path_exists,
						version = version,
						project = project_path,
					},
				}
			end
		end
	end
	if parsed then
		entries = dedupe_by_final(entries)
	end
	local r = {}
	for i = #entries, 1, -1 do
		r[#r + 1] = entries[i]
	end
	return r
end
